#!/usr/bin/env bash

# Uploads a file to overwrite the stable release on Nextcloud.
# The stable path is a fixed location whose files are already shared
# via permanent public links.

set -euo pipefail

build_dir="$(realpath "$(dirname "${BASH_SOURCE[0]}")")"
readonly build_dir

readonly ci_file_to_upload="${1:?File to upload not specified}"
readonly ci_stable_filename="${2:?Stable filename not specified}"

{
    echo "${NEXTCLOUD_PASSWORD:?}"
    echo "${NEXTCLOUD_USERNAME:?}"
} > /dev/null

readonly ci_dl_server=https://dl.sevencourts.com
readonly ci_stable_path='SevenCourts%20Firmware%20Tarball/_stable'

export WEBDAV_PASSWORD="$NEXTCLOUD_PASSWORD"
export WEBDAV_USERNAME="$NEXTCLOUD_USERNAME"
export WEBDAV_OVERWRITE=true

source "$build_dir/lib/webdav.bash"

# Rename the file to the stable name for upload
src="$(realpath "$ci_file_to_upload")"
dst="/tmp/$ci_stable_filename"
if [ "$src" != "$(realpath "$dst" 2>/dev/null)" ]; then
    cp "$src" "$dst"
fi

webdav__upload_file \
    "$ci_dl_server/remote.php/webdav" "$ci_stable_path" "/tmp/$ci_stable_filename"

echo "Updated stable: $ci_stable_path/$ci_stable_filename"
