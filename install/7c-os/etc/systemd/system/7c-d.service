[Unit]
Description=SevenCourts controller daemon

Requires=wpa_supplicant.service 7c-hostname.service
After=network-online.target bluetooth.target 7c-hostname.service

[Service]
Type=simple
Restart=always
RestartSec=5

## Dirs
ProtectHome=true
WorkingDirectory=/opt/7c

ExecStart=/opt/7c/sevencourts-daemon --log=debug run

[Install]
WantedBy=multi-user.target
